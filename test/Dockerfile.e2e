FROM golang:1.25 AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -trimpath -o /shard-proxy . && \
    CGO_ENABLED=0 go build -trimpath -o /send-test-frames ./cmd/send-test-frames/ && \
    CGO_ENABLED=0 go build -trimpath -o /recv-test-frames ./cmd/recv-test-frames/

FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        iproute2 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /shard-proxy /usr/local/bin/shard-proxy
COPY --from=builder /send-test-frames /usr/local/bin/send-test-frames
COPY --from=builder /recv-test-frames /usr/local/bin/recv-test-frames

COPY test/run-e2e.sh /run-e2e.sh
RUN chmod +x /run-e2e.sh

ENTRYPOINT ["/run-e2e.sh"]
